# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# ห้ามอัปโหลดไฟล์ .env ขึ้น GitHub เด็ดขาด!

# Supabase — หาได้ที่: Project Settings > API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Telegram Bot — สร้าง Bot ได้ที่ @BotFather บน Telegram
VITE_TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
VITE_TELEGRAM_CHAT_ID=YOUR_CHAT_ID            # แชทหลัก — ลูกค้ากรอกสำเร็จ
VITE_TELEGRAM_ERROR_CHAT_ID=YOUR_ERROR_CHAT_ID  # แชท error — ส่งไม่สำเร็จ
